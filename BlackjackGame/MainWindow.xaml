<Window x:Class="BlackjackGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BlackjackGame"
        mc:Ignorable="d"
        xmlns:views="clr-namespace:BlackjackGame.Views"
        Height="1000" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#222" Padding="10">
            <TextBlock Text="Blackjack"
                   Foreground="White"
                   FontSize="18"/>
        </Border>

        <!-- GAME -->
        <Border Grid.Row="1"
            Background="DarkGreen"
            Padding="10"
            Margin="10"
            CornerRadius="10">

            <views:BlackjackView />

        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="#222" Padding="10">
            <TextBlock Text="Press H to Hit, S to Stand"
                   Foreground="White"/>
        </Border>

    </Grid>

</Window>
