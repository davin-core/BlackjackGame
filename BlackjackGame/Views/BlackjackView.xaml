<UserControl x:Class="BlackjackGame.Views.BlackjackView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BlackjackGame.Views"
        Focusable="True"     
        mc:Ignorable="d">

    <Grid Background="#1B5E20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Credits Display -->
        <Border Grid.Row="0" Background="#145a1f" Padding="10" Margin="10,5,10,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Credits: " 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White"/>
                <TextBlock Text="{Binding Credits}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#FFD700"/>
                <TextBlock Text=" | " 
                           FontSize="18" 
                           Foreground="White"
                           Margin="10,0"/>
                <TextBlock Text="{Binding CreditChangeMessage}" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#FF6B6B"/>
            </StackPanel>
        </Border>

        <!-- Dealer Area -->
        <StackPanel Grid.Row="1" Margin="10,10,10,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Dealer"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"/>
                <!--<TextBlock Text="{Binding DealerHandValue}"
                           FontSize="16"
                           Foreground="Yellow"
                           Margin="20,0,0,0"/>
                -->
            </StackPanel>

            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding DealerHand.Cards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="White"
                                    BorderThickness="2"
                                    Margin="8"
                                    CornerRadius="4"
                                    Background="White">

                                <Image Source="{Binding ImagePath}"
                                   Stretch="Uniform"
                                   MaxWidth="160"
                                   MaxHeight="225"/>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <!-- Game Status -->
        <TextBlock Grid.Row="2"
                   Text="{Binding GameStatus}"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="Yellow"
                   Background="#145a1f"
                   Padding="10"
                   TextAlignment="Center"
                   Margin="10,5,10,5"/>

        <!-- Player Area -->
        <StackPanel Grid.Row="3" Margin="10,10,10,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Player"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="{Binding PlayerHandValue}"
                           FontSize="16"
                           Foreground="Yellow"
                           Margin="20,0,0,0"/>
            </StackPanel>

            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding PlayerHand.Cards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="White"
                                    BorderThickness="2"
                                    Margin="8"
                                    CornerRadius="4"
                                    Background="White">

                                <Image Source="{Binding ImagePath}"
                                   Stretch="Uniform"
                                   MaxWidth="160"
                                   MaxHeight="225"/>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <!-- Control Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="10,10,10,10" HorizontalAlignment="Center">
            <Button Content="Hit" 
                    Width="100" 
                    Height="40"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#4CAF50"
                    Foreground="White"
                    Command="{Binding HitCommand}"
                    Margin="5"/>
            <Button Content="Stand" 
                    Width="100" 
                    Height="40"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#2196F3"
                    Foreground="White"
                    Command="{Binding StandCommand}"
                    Margin="5"/>
            <Button Content="Next Game" 
                    Width="100" 
                    Height="40"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#9C27B0"
                    Foreground="White"
                    Command="{Binding NextGameCommand}"
                    Margin="5"/>
            <Button Content="New Game" 
                    Width="100" 
                    Height="40"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#FF9800"
                    Foreground="White"
                    Command="{Binding NewGameCommand}"
                    Margin="5"/>
        </StackPanel>

    </Grid>
</UserControl>
